#!/bin/bash

set -e

show_help() {
    echo "usage: $(basename "$0") [-v <version>] [-o <output-dir>] [-g] [-s] [-h]"
    echo "       -v <version>       set version"
    echo "       -o <output-dir>    write source packages to this directory"
    echo "       -g                 use 'git describe' output as version string"
    echo "       -s                 use single source archive instead of no-vendor and"
    echo "                          only-vendor packages"
    echo "       -h                 show help"
    exit 1
}

if [ ! -e "packaging/$(basename "$0")" ]; then
    echo "must be executed at the top of srcdir"
    exit 1
fi

outdir=.
single=0

while getopts "v:o:gsh" arg; do
    case "$arg" in
        o)
            outdir="$OPTARG"
            ;;
        v)
            version="$OPTARG"
            ;;
        g)
            version="$(git describe | tr '-' '.')"
            ;;
        s)
            single=1
            ;;
        h|*)
            show_help
            ;;
    esac
done

if [ -z "$version" ]; then
    echo "error: version is unset"
    exit 1
fi

# Determine SNAPD_ASSERTS_FORMATS by running asserts/info from the source tree.
go_mod_flags=()
if [ -d "vendor/github.com" ]; then
    go_mod_flags=("-mod=vendor")
fi
asserts_formats=$(go run "${go_mod_flags[@]}" ./asserts/info)

set -x

# Create a temporary directory for generated files and intermediate work.
gendir=$(mktemp -d)
tmpdir=$(mktemp -d)
trap 'rm -rf "$gendir" "$tmpdir"' EXIT

# Generate the version-dependent files that are not tracked by git.
mkdir -p "$gendir/data" "$gendir/cmd" "$gendir/snapdtool"

printf 'VERSION=%s\nVERSION_DISTRO_PATCH=\nSNAPD_APPARMOR_REEXEC=1\n%s\n' "$version" "$asserts_formats" \
    >"$gendir/data/info"

printf '%s\n' "$version" >"$gendir/cmd/VERSION"

cat >"$gendir/snapdtool/version_generated.go" <<EOF
package snapdtool

// generated by pack-source; do not edit

func init() {
	Version = "$version"
	VersionDistroPatch = ""
}
EOF

# append_generated appends the three generated files from gendir into the
# uncompressed tar archive at the given path, under the snapd-$version/ prefix.
append_generated() {
    local tarfile="$1"
    tar --append \
        --file="$tarfile" \
        --directory="$gendir" \
        --transform "s|^\./|snapd-$version/|" \
        ./data/info ./cmd/VERSION ./snapdtool/version_generated.go
}

if [[ "$single" == 0 ]]; then
    # no-vendor tarball: git-tracked files (vendor is not tracked) plus generated files.
    tmptar="$tmpdir/no-vendor.tar"
    git archive HEAD --prefix="snapd-$version/" --format=tar >"$tmptar"
    append_generated "$tmptar"
    xz -c "$tmptar" >"$outdir/snapd_${version}.no-vendor.tar.xz"

    # only-vendor tarball: the Go vendor tree and C vendor tree from the working
    # directory (populated by go mod vendor / c-vendor/vendor.sh before this
    # script is invoked).
    tar -cJf "$outdir/snapd_${version}.only-vendor.tar.xz" \
        --transform "s|^|snapd-$version/|" \
        vendor c-vendor
else
    # Single tarball: git-tracked files plus vendor trees and generated files.
    tmptar="$tmpdir/vendor.tar"
    git archive HEAD --prefix="snapd-$version/" --format=tar >"$tmptar"
    tar --append \
        --file="$tmptar" \
        --transform "s|^|snapd-$version/|" \
        vendor c-vendor
    append_generated "$tmptar"
    xz -c "$tmptar" >"$outdir/snapd_${version}.vendor.tar.xz"
fi

#!/bin/bash

# pack-source - Create source tarballs for snapd packaging
#
# PREREQUISITES: This script must be called AFTER both vendoring steps have been
# completed:
#
#   1. Go modules:  run "go mod vendor" in the source tree root
#   2. C vendor:    run "c-vendor/vendor.sh" in the c-vendor directory
#
# The script validates that both vendor/github.com and c-vendor/squashfuse
# directories are present and fails with a clear error if they are not.
#

set -e

show_help() {
	echo "usage: $(basename "$0") [-v <version>] [-o <output-dir>] [-g] [-s] [-h]"
	echo "       -v <version>       set version"
	echo "       -o <output-dir>    write source packages to this directory"
	echo "       -g                 use 'git describe' output as version string"
	echo "       -s                 use single source archive instead of no-vendor and"
	echo "                          only-vendor packages"
	echo "       -h                 show help"
	exit 1
}

if [ ! -e "packaging/$(basename "$0")" ]; then
	echo "must be executed at the top of srcdir"
	exit 1
fi

outdir=.
single=0

while getopts "v:o:gsh" arg; do
	case "$arg" in
	o)
		outdir="$OPTARG"
		;;
	v)
		version="$OPTARG"
		;;
	g)
		version="$(git describe | tr '-' '.')"
		;;
	s)
		single=1
		;;
	h | *)
		show_help
		;;
	esac
done

if [ -z "$version" ]; then
	echo "error: version is unset"
	exit 1
fi

# Validate that both vendoring steps have been completed before this script
# is invoked.  These checks provide clear error messages instead of cryptic
# failures later when tar tries to include missing directories.
if [ ! -d "vendor/github.com" ]; then
	echo "error: vendor/github.com directory not found"
	echo "       Run 'go mod vendor' in the source tree root first."
	exit 1
fi

if [ ! -d "c-vendor/squashfuse" ]; then
	echo "error: c-vendor/squashfuse directory not found"
	echo "       Run 'c-vendor/vendor.sh' in the c-vendor directory first."
	exit 1
fi

# Determine SNAPD_ASSERTS_FORMATS by running asserts/info from the source tree.
# The vendor directory is guaranteed to exist here because of the validation
# checks above (pack-source must be called after "go mod vendor").
asserts_formats="$(go run -mod=vendor ./asserts/info)"

# Create a temporary directory for generated files and intermediate work.
gendir=$(mktemp -d)
tmpdir=$(mktemp -d)
trap 'rm -rf "$gendir" "$tmpdir"' EXIT

# Generate the version-dependent files that are not tracked by git.
mkdir -p "$gendir/data" "$gendir/cmd" "$gendir/snapdtool"

# SNAPD_APPARMOR_REEXEC is set to 1 (enabled) by default. This will flip when
# we move the decision to the per-distribution packaging directory. Note that
# "$asserts_formats" contains the key SNAPD_ASSERTS_FORMATS= as well as the
# value.
printf 'VERSION=%s\nSNAPD_APPARMOR_REEXEC=1\n%s\n' "$version" "$asserts_formats" >"$gendir/data/info"

printf '%s\n' "$version" >"$gendir/cmd/VERSION"

cat >"$gendir/snapdtool/version_generated.go" <<EOF
package snapdtool

// generated by pack-source; do not edit

func init() {
	Version = "$version"
}
EOF

# append_generated appends the three generated files from gendir into the
# uncompressed tar archive at the given path, under the snapd-$version/ prefix.
append_generated() {
	local tarfile="$1"
	tar --append \
		--file="$tarfile" \
		--directory="$gendir" \
		--transform "s|^\./|snapd-$version/|" \
		./data/info ./cmd/VERSION ./snapdtool/version_generated.go
}

if [ "$single" -eq 0 ]; then
	# no-vendor tarball: git-tracked files (vendor is not tracked) plus generated files.
	tmptar="$tmpdir/no-vendor.tar"
	git archive HEAD --prefix="snapd-$version/" --format=tar >"$tmptar"
	append_generated "$tmptar"
	xz -c "$tmptar" >"$outdir/snapd_${version}.no-vendor.tar.xz"

	# only-vendor tarball: the Go vendor tree and C vendor tree from the working
	# directory (populated by go mod vendor / c-vendor/vendor.sh before this
	# script is invoked). Exclude c-vendor/README and c-vendor/vendor.sh as they
	# are git-tracked and already included in the no-vendor tarball.
	tar -cJf "$outdir/snapd_${version}.only-vendor.tar.xz" \
		--transform "s|^|snapd-$version/|" \
		--exclude='c-vendor/README' \
		--exclude='c-vendor/vendor.sh' \
		vendor c-vendor

	# vendor tarball: all files (git-tracked plus vendor trees and generated
	# files). This is kept for backward compatibility with Arch packaging.
	tmptar="$tmpdir/vendor.tar"
	git archive HEAD --prefix="snapd-$version/" --format=tar >"$tmptar"
	# Append only the untracked vendor outputs.  c-vendor/README and
	# c-vendor/vendor.sh are already in the git archive, excluding them
	# from tar --append avoids duplicate entries in the final tarball.
	tar --append \
		--file="$tmptar" \
		--transform "s|^|snapd-$version/|" \
		--exclude='c-vendor/README' \
		--exclude='c-vendor/vendor.sh' \
		vendor c-vendor
	append_generated "$tmptar"
	xz -c "$tmptar" >"$outdir/snapd_${version}.vendor.tar.xz"
else
	# Single tarball: git-tracked files plus vendor trees and generated files.
	tmptar="$tmpdir/vendor.tar"
	git archive HEAD --prefix="snapd-$version/" --format=tar >"$tmptar"
	tar --append \
		--file="$tmptar" \
		--transform "s|^|snapd-$version/|" \
		--exclude='c-vendor/README' \
		--exclude='c-vendor/vendor.sh' \
		vendor c-vendor
	append_generated "$tmptar"
	xz -c "$tmptar" >"$outdir/snapd_${version}.vendor.tar.xz"
fi

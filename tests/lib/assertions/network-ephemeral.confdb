type: confdb-schema
authority-id: developer1
account-id: developer1
name: network-ephemeral
timestamp: 2026-06-12T12:00:00Z
views:
  wifi-admin:
    rules:
      -
        request: ssids
        storage: v1.wifi.ssids
      -
        request: ssid
        storage: v1.wifi.ssid
      -
        request: password
        storage: v1.wifi.psk
      -
        request: status
        storage: v1.wifi.status
body-length: 631
sign-key-sha3-384: EAD4DbLxK_kn0gzNCXOs3kd6DeMU3f-L6BEsSEuJGBqCORR0gXkdDxMbOm11mRFu

{
  "storage": {
    "aliases": {
      "status-str": {
        "choices": [
          "off",
          "on"
        ],
        "type": "string"
      }
    },
    "schema": {
      "v1": {
        "schema": {
          "wifi": {
            "schema": {
              "psk": {
                "ephemeral": true,
                "type": "string"
              },
              "ssid": "string",
              "ssids": {
                "type": "array",
                "unique": true,
                "values": "string"
              },
              "status": "${status-str}"
            }
          }
        }
      }
    }
  }
}

